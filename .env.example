# AI provider selection
# Supported values: gemini, minimax
AI_PROVIDER="minimax"

# Gemini provider
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# MiniMax provider
MINIMAX_API_KEY="MY_MINIMAX_API_KEY"
# Optional. `sk-api-...` keys default to the OpenAI-compatible endpoint.
# `sk-cp-...` Token Plan keys default to the Anthropic-compatible endpoint.
MINIMAX_BASE_URL="https://api.minimax.io/v1"

# Optional task-level model overrides
AI_MODEL_PLAN=""
AI_MODEL_HINT=""
AI_MODEL_REVIEW=""

# App URL
APP_URL="MY_APP_URL"
